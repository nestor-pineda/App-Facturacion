generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EstadoQuote {
  borrador
  enviado
}

enum EstadoInvoice {
  borrador
  enviada
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  nombre_comercial String
  nif              String
  direccion_fiscal String
  telefono         String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  clients  Client[]
  services Service[]
  quotes   Quote[]
  invoices Invoice[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  user_id   String
  nombre    String
  email     String
  cif_nif   String
  direccion String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User      @relation(fields: [user_id], references: [id])
  quotes   Quote[]
  invoices Invoice[]

  @@map("clients")
}

model Service {
  id             String   @id @default(uuid())
  user_id        String
  nombre         String
  descripcion    String?
  precio_base    Decimal  @db.Decimal(10, 2)
  iva_porcentaje Decimal  @default(21.00) @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  quote_lines  QuoteLine[]
  invoice_lines InvoiceLine[]

  @@map("services")
}

model Quote {
  id         String      @id @default(uuid())
  user_id    String
  client_id  String
  numero     String?
  estado     EstadoQuote @default(borrador)
  fecha      DateTime    @db.Date
  subtotal   Decimal     @default(0) @db.Decimal(10, 2)
  total_iva  Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @default(0) @db.Decimal(10, 2)
  notas      String?
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  user   User        @relation(fields: [user_id], references: [id])
  client Client      @relation(fields: [client_id], references: [id])
  lines  QuoteLine[]

  @@map("quotes")
}

model QuoteLine {
  id              String   @id @default(uuid())
  quote_id        String
  service_id      String?
  descripcion     String
  cantidad        Decimal  @db.Decimal(10, 2)
  precio_unitario Decimal  @db.Decimal(10, 2)
  iva_porcentaje  Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  quote   Quote    @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [service_id], references: [id], onDelete: SetNull)

  @@map("quote_lines")
}

model Invoice {
  id            String        @id @default(uuid())
  user_id       String
  client_id     String
  numero        String?       @unique
  estado        EstadoInvoice @default(borrador)
  fecha_emision DateTime      @db.Date
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  total_iva     Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @default(0) @db.Decimal(10, 2)
  notas         String?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  user   User          @relation(fields: [user_id], references: [id])
  client Client        @relation(fields: [client_id], references: [id])
  lines  InvoiceLine[]

  @@map("invoices")
}

model InvoiceLine {
  id              String   @id @default(uuid())
  invoice_id      String
  service_id      String?
  descripcion     String
  cantidad        Decimal  @db.Decimal(10, 2)
  precio_unitario Decimal  @db.Decimal(10, 2)
  iva_porcentaje  Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [service_id], references: [id], onDelete: SetNull)

  @@map("invoice_lines")
}
