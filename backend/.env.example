# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/facturacion_db"

# JWT (≥32 caracteres cada uno; deben ser distintos o el servidor no arranca — refine Zod en env.ts)
JWT_SECRET="cambia-esto-por-un-secreto-de-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambia-esto-por-otro-secreto-de-minimo-32-caracteres"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV="development"

# CORS / anti-CSRF (debe coincidir con el origen del navegador: host, puerto y esquema exactos)
# El Vite de este repo usa el puerto 8080 (ver frontend/vite.config.ts). Incluye 5173 si usas el default de Vite.
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:5173"

# Google AI (Genkit / agente IA) — https://aistudio.google.com/apikey
# Opcional en despliegue: sin valor el API arranca; el chat del agente responde 503 hasta que configures la clave.
GOOGLE_GENAI_API_KEY=your-google-ai-api-key-here

# SMTP — para que "Enviar" mande el presupuesto/factura al email del cliente (opcional).
# Sin SMTP_HOST el estado pasa a "Enviado" pero no se envía correo.
# Desarrollo: crea cuenta en https://mailtrap.io y usa sus credenciales SMTP del inbox.
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=tu_user_mailtrap
# SMTP_PASS=tu_pass_mailtrap
# SMTP_FROM="Facturación App <noreply@facturacion.app>"
